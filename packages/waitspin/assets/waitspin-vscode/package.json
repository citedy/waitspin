{
  "name": "waitspin-vscode",
  "displayName": "WaitSpin: Sponsored Wait States",
  "description": "Earn from VS Code wait states with sponsored cards, wallet status, and ledger visibility without giving WaitSpin access to your code.",
  "version": "0.1.16",
  "publisher": "waitspin",
  "license": "AGPL-3.0-or-later",
  "icon": "media/waitspin-icon.png",
  "homepage": "https://waitspin.com/docs",
  "bugs": {
    "url": "https://github.com/citedy/waitspin/issues"
  },
  "qna": false,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "waitspin",
    "developer-earnings",
    "sponsored-cards",
    "wallet",
    "ledger",
    "vscode",
    "vscode-extension",
    "sponsored",
    "wait-state",
    "activity-bar",
    "status-bar",
    "impressions",
    "developer-monetization",
    "ai-agents",
    "ads",
    "developer-tools"
  ],
  "galleryBanner": {
    "color": "#101820",
    "theme": "dark"
  },
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onCommand:waitspin.connectPublisher",
    "onCommand:waitspin.activatePublisher",
    "onView:waitspin.publisherView"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/citedy/waitspin.git",
    "directory": "extensions/waitspin-vscode"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "waitspin.connectPublisher",
        "title": "WaitSpin: Connect and earn"
      },
      {
        "command": "waitspin.activatePublisher",
        "title": "WaitSpin: Start sponsor polling"
      },
      {
        "command": "waitspin.refreshWallet",
        "title": "WaitSpin: Refresh wallet"
      },
      {
        "command": "waitspin.openAd",
        "title": "WaitSpin: Open sponsored link"
      },
      {
        "command": "waitspin.openDocs",
        "title": "WaitSpin: Open docs"
      },
      {
        "command": "waitspin.openMarket",
        "title": "WaitSpin: Open market"
      },
      {
        "command": "waitspin.openCliInstallHelp",
        "title": "WaitSpin: Install or update CLI"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "waitspin",
          "title": "WaitSpin",
          "icon": "media/waitspin-activitybar.svg"
        }
      ]
    },
    "views": {
      "waitspin": [
        {
          "id": "waitspin.publisherView",
          "name": "WaitSpin",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "WaitSpin",
      "properties": {
        "waitspin.installId": {
          "type": "string",
          "default": "",
          "description": "Optional fallback WaitSpin install ID. The WaitSpin: Connect and earn command stores the install ID in VS Code global extension state."
        },
        "waitspin.apiBase": {
          "type": "string",
          "default": "https://api.waitspin.com",
          "description": "WaitSpin control API base URL. Credentialed polling trusts only user settings and https://api.waitspin.com by default."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@types/vscode": "^1.85.0",
    "typescript": "5.9.2"
  }
}
